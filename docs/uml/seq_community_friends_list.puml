@startuml
title Community service - list friends with profile aggregation

actor User
participant "Social dock / Friends tab" as FE
participant "gRPC Gateway\nUserRoutes" as Gateway
participant "Community UserGrpc" as UserGrpc
participant "UserService" as UserService
database "MongoDB" as Mongo

User -> FE : opens side friends panel
FE -> Gateway : GET /v1/users/{user_id}/friends?friend_status=ACCEPTED
Gateway -> UserGrpc : GetFriends(ListFriendsRequest)
UserGrpc -> UserService : get_friends(user_id, status)
UserService -> Mongo : find Friend where user_id_1=user_id or user_id_2=user_id
Mongo --> UserService : Friend[]
UserService --> UserGrpc : ListFriendsResponse
UserGrpc --> Gateway : Friend[]

loop for each friendship
  Gateway -> Gateway : resolve other_user_id
  Gateway -> UserGrpc : GetUser(other_user_id)
  UserGrpc -> UserService : get_user(other_user_id)
  UserService -> Mongo : find User
  Mongo --> UserService : User
  UserService --> UserGrpc : UserResponse
  UserGrpc --> Gateway : UserResponse
end

Gateway -> Gateway : compose FriendListItem(friendship, user)
Gateway --> FE : FriendListItem[]
FE -> FE : render friends list and mini-chat actions

@enduml
